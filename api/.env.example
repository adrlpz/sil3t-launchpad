# siL3t API — Environment Config

# Server
PORT=3001

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/sil3t

# Redis
REDIS_URL=redis://localhost:6379

# RPC URLs
BASE_RPC_URL=https://mainnet.base.org
BASE_WS_URL=wss://base-mainnet.g.alchemy.com/v2/YOUR_KEY
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
ARBITRUM_WS_URL=wss://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
ETH_RPC_URL=https://eth.llamarpc.com
ETH_WS_URL=wss://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# Contract Addresses (fill after deployment)
BASE_MARGIN_ENGINE=0x0000000000000000000000000000000000000000
ARBITRUM_MARGIN_ENGINE=0x0000000000000000000000000000000000000000
ETH_MARGIN_ENGINE=0x0000000000000000000000000000000000000000

# Keeper Wallet (for liquidation execution)
KEEPER_PRIVATE_KEY=

# Alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
